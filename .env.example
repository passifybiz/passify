# ─────────────────────────────────────────────────────────────
# Passify environment. Copy to `.env` and fill in.
# ─────────────────────────────────────────────────────────────

# Provider mode. "mock" (default) = full working UX with zero keys/SOL.
# "real" = wire Blockpass/Helius/Solana (needs the *_KEY vars below).
PROVIDER=mock

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://passify:passify@localhost:5432/passify

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Dashboard session JWT — any long random string
SESSION_SECRET=change-me-to-a-long-random-string

# ── Real-provider creds (only needed when PROVIDER=real) ──────
# Helius RPC + DAS API
HELIUS_API_KEY=
# Blockpass KYC
BLOCKPASS_CLIENT_ID=
BLOCKPASS_WEBHOOK_SECRET=
BLOCKPASS_API_KEY=
# Passify onchain attester keypair (base58). NEVER commit a real one.
ATTESTER_KEYPAIR_BASE58=
# Existing attestation program id the TRD assumes is already deployed.
# Without a confirmed program the real attestation WRITE is best-effort;
# the mock gives the full UX. See README.
ATTESTATION_PROGRAM_ID=

# App
APP_URL=http://localhost:3000


# ── Error tracking (optional) ─────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
