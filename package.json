{
  "name": "passify",
  "version": "1.0.0",
  "private": true,
  "description": "Identity Proven. Assets Unlocked. — API-first identity and compliance layer for Solana RWA platforms.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:migrate:apply": "tsx drizzle/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx drizzle/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@sentry/nextjs": "^8.55.2",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "next": "15.5.19",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.30.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.19",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.1.3"
  }
}
